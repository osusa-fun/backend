# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/osusa?schema=public"

# Bags.fm API - Get your key from https://dev.bags.fm
BAGS_API_KEY=""

# Solana RPC URL - Use devnet for testing
SOLANA_RPC_URL="https://api.devnet.solana.com"

# Platform authority keypair (base58 encoded)
# Generate with: solana-keygen new --outfile platform.json
PLATFORM_KEYPAIR=""

# AES-256 encryption key (32 bytes hex)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# Server port
PORT=3001